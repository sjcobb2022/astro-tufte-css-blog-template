---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  frontmatter?: { title?: string };
  title?: string;
}
const { frontmatter, title } = Astro.props;
const pageTitle = frontmatter?.title ?? title;
---

<BaseLayout title={pageTitle}>
  <slot />
</BaseLayout>

<style is:global>
  article {
    counter-reset: sidenote-counter;
  }
</style>
